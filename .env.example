# PostgreSQL
POSTGRES_USER=template_user
POSTGRES_PASSWORD=template_dev_password
POSTGRES_DB=template_db

# JWT
SECRET_KEY=CHANGE_ME_IN_PRODUCTION
ALGORITHM=HS256

# Environment
ENV=dev

# Frontend
VITE_API_URL=http://localhost:5462/api
FRONTEND_URL=http://localhost:5462

# SMTP (optional)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Nexora
EMAIL_ENABLED=false

# Web Push VAPID (optional)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:noreply@example.com
PUSH_ENABLED=false

# Maintenance commands (cron)
NOTIFICATION_PURGE_DAYS=90
EVENT_RETENTION_DAYS=180
PUSH_SUBSCRIPTION_RETENTION_DAYS=90
IMPERSONATION_LOG_RETENTION_DAYS=180
COMMAND_LOG_RETENTION_DAYS=90

# Intranet SSO (optional)
INTRANET_AUTH_URL=
INTRANET_EMAIL_DOMAIN=

# Seed defaults
DEFAULT_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_ROLE_SLUG=super_admin
