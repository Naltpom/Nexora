# Environment variables
.env
.env.local
.env.*.local

# Project-specific config (never touched by template)
config.custom.yaml

# Project-specific features (never touched by template)
# Note: features/ dirs (api/src/features/, app/src/features/) are tracked but their contents are project-specific

