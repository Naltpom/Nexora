# ══════════════════════════════════════════════════════════════════════
# Production Environment — copy to .env at project root
# Secrets are managed via Docker Secrets (./secrets/ directory)
# ══════════════════════════════════════════════════════════════════════

# ── Domain ───────────────────────────────────────────────────────────
DOMAIN=app.example.com

# ── Environment ──────────────────────────────────────────────────────
ENV=production

# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_USER=nexora_prod
POSTGRES_PASSWORD=SET_VIA_DOCKER_SECRET
POSTGRES_DB=nexora_prod
POSTGRES_HOST=pgbouncer
POSTGRES_PORT=6432

# ── JWT ──────────────────────────────────────────────────────────────
# Secret managed via Docker Secret (./secrets/secret_key)
SECRET_KEY=SET_VIA_DOCKER_SECRET
ALGORITHM=HS256

# ── Encryption ───────────────────────────────────────────────────────
# Fernet key managed via Docker Secret (./secrets/encryption_key)
ENCRYPTION_KEY=SET_VIA_DOCKER_SECRET

# ── Frontend ─────────────────────────────────────────────────────────
VITE_API_URL=https://app.example.com/api
FRONTEND_URL=https://app.example.com

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=https://app.example.com

# ── SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=SET_VIA_DOCKER_SECRET
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Nexora
EMAIL_ENABLED=true

# ── Web Push VAPID ───────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@example.com
PUSH_ENABLED=false

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://:SET_VIA_DOCKER_SECRET@redis:6379/0
REDIS_PASSWORD=SET_VIA_DOCKER_SECRET

# ── Meilisearch ──────────────────────────────────────────────────────
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=SET_VIA_DOCKER_SECRET
MEILISEARCH_ENABLED=true
MEILISEARCH_ENV=production

# ── Antivirus ────────────────────────────────────────────────────────
ANTIVIRUS_ENABLED=true
ANTIVIRUS_HOST=clamav
ANTIVIRUS_PORT=3310

# ── SSO (optional) ──────────────────────────────────────────────────
SSO_GOOGLE_CLIENT_ID=
SSO_GOOGLE_CLIENT_SECRET=
SSO_GOOGLE_REDIRECT_URI=https://app.example.com/sso/callback/google
SSO_GITHUB_CLIENT_ID=
SSO_GITHUB_CLIENT_SECRET=
SSO_GITHUB_REDIRECT_URI=https://app.example.com/sso/callback/github

# ── Admin ────────────────────────────────────────────────────────────
DEFAULT_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_ROLE_SLUG=super_admin

# ── Uvicorn ──────────────────────────────────────────────────────────
UVICORN_WORKERS=4

# ── Rate limiting ────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true

# ── File storage ─────────────────────────────────────────────────────
STORAGE_BACKEND=local
UPLOAD_QUOTA_MB=500
