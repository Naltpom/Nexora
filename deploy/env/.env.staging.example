# ══════════════════════════════════════════════════════════════════════
# Staging Environment — copy to .env at project root
# Secrets are managed via Docker Secrets (./secrets/ directory)
# ══════════════════════════════════════════════════════════════════════

# ── Domain ───────────────────────────────────────────────────────────
DOMAIN=staging.example.com

# ── Environment ──────────────────────────────────────────────────────
ENV=staging

# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_USER=nexora_staging
POSTGRES_PASSWORD=SET_VIA_DOCKER_SECRET
POSTGRES_DB=nexora_staging
POSTGRES_HOST=pgbouncer
POSTGRES_PORT=6432

# ── JWT ──────────────────────────────────────────────────────────────
SECRET_KEY=SET_VIA_DOCKER_SECRET
ALGORITHM=HS256

# ── Encryption ───────────────────────────────────────────────────────
ENCRYPTION_KEY=SET_VIA_DOCKER_SECRET

# ── Frontend ─────────────────────────────────────────────────────────
VITE_API_URL=https://staging.example.com/api
FRONTEND_URL=https://staging.example.com

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=https://staging.example.com

# ── SMTP (disabled in staging) ───────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=SET_VIA_DOCKER_SECRET
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Nexora Staging
EMAIL_ENABLED=false

# ── Web Push (disabled in staging) ───────────────────────────────────
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@example.com
PUSH_ENABLED=false

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://:SET_VIA_DOCKER_SECRET@redis:6379/0
REDIS_PASSWORD=SET_VIA_DOCKER_SECRET

# ── Meilisearch ──────────────────────────────────────────────────────
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=SET_VIA_DOCKER_SECRET
MEILISEARCH_ENABLED=true
MEILISEARCH_ENV=production

# ── Antivirus ────────────────────────────────────────────────────────
ANTIVIRUS_ENABLED=false
ANTIVIRUS_HOST=clamav
ANTIVIRUS_PORT=3310

# ── Admin ────────────────────────────────────────────────────────────
DEFAULT_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_ROLE_SLUG=super_admin

# ── Uvicorn (fewer workers for staging) ──────────────────────────────
UVICORN_WORKERS=2

# ── Rate limiting ────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true

# ── File storage ─────────────────────────────────────────────────────
STORAGE_BACKEND=local
UPLOAD_QUOTA_MB=100
